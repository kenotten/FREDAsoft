# GEMINI_API_KEY: Server-only. Used by POST /api/gemini (Express). Never bundled into the client.
# Set in .env.local for local dev (loaded by server.ts via dotenv). Do not add to Vite define/import.meta.env.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
